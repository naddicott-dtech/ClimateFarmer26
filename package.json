{
  "name": "climate-farmer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --exclude tests/engine/balance/balance-smoke.test.ts --exclude tests/engine/balance/balance-full.test.ts",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "test:balance": "vitest run tests/engine/balance/balance-smoke.test.ts --reporter=verbose",
    "test:balance-full": "vitest run tests/engine/balance/balance-full.test.ts --reporter=verbose",
    "test:all": "vitest run --exclude tests/engine/balance/balance-smoke.test.ts --exclude tests/engine/balance/balance-full.test.ts && playwright test",
    "generate-seeds": "npx tsx scripts/generate-curated-seeds.ts"
  },
  "dependencies": {
    "preact": "^10.27.2",
    "@preact/signals": "^1.3.1"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@types/node": "^24.10.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.1.1",
    "@playwright/test": "^1.52.0"
  }
}
